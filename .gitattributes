# Normalise line endings. Shell scripts MUST stay LF so they run on Linux even
# when committed from Windows.
* text=auto eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.webp binary
*.db binary
*.sqlite binary
