{
  "name": "forgelink",
  "version": "1.0.0",
  "private": true,
  "description": "ForgeLink is a custom launcher builder and deployment platform for game servers. Turn your 7 Days to Die (and other) dedicated server into a branded, auto-updating launcher with automatic mod sync, file verification, live server status and one-command Linux deployment.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "ForgeLink",
  "homepage": "https://github.com/AlphaNodesDev/forgelink#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlphaNodesDev/forgelink.git"
  },
  "bugs": {
    "url": "https://github.com/AlphaNodesDev/forgelink/issues"
  },
  "keywords": [
    "7-days-to-die",
    "7dtd",
    "game-launcher",
    "launcher-builder",
    "game-server",
    "dedicated-server",
    "mod-sync",
    "mod-synchronizer",
    "auto-updater",
    "modpack-launcher",
    "minecraft-launcher",
    "server-tools",
    "electron",
    "game-launcher-generator"
  ],
  "workspaces": [
    "packages/shared",
    "packages/adapters",
    "packages/server-api",
    "packages/builder",
    "packages/launcher"
  ],
  "scripts": {
    "build": "npm run build --workspace=@forgelink/shared && npm run build --workspace=@forgelink/adapters && npm run build --workspace=@forgelink/server-api",
    "build:shared": "npm run build --workspace=@forgelink/shared",
    "build:adapters": "npm run build --workspace=@forgelink/adapters",
    "build:server": "npm run build --workspace=@forgelink/server-api",
    "dev:server": "npm run dev --workspace=@forgelink/server-api",
    "dev:builder": "npm run dev --workspace=@forgelink/builder",
    "dev:launcher": "npm run dev --workspace=@forgelink/launcher",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "node scripts/clean.mjs"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "rimraf": "^6.0.1",
    "@types/node": "^22.5.0"
  }
}
