{
  "name": "@forgelink/launcher",
  "version": "1.0.0",
  "description": "ForgeLink Launcher — branded, generated game-server launcher with mod sync and auto-update.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "AlphaNodesDev",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlphaNodesDev/forgelink.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build",
    "package": "npm run build && electron-builder --publish never",
    "clean": "rimraf dist dist-electron release",
    "test": "node --test"
  },
  "dependencies": {
    "@forgelink/adapters": "1.0.0",
    "@forgelink/shared": "1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^31.3.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.41",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.forgelink.launcher",
    "productName": "ForgeLink Launcher",
    "electronVersion": "31.3.0",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "launcher-config.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
